# 复制此文件为 .env 并填入你的 API 密钥
# cp .env.example .env

# 智谱AI GLM API Key (必填，从 https://open.bigmodel.cn/usercenter/apikeys 获取)
GLM_API_KEY=你的密钥

# 可选：Gemini API Key
# GEMINI_API_KEY=你的密钥

# 模型选择 (默认 glm-4v-plus)
GLM_MODEL=glm-4v-plus

# WebSocket 分析节流 (秒)
ANALYZE_THROTTLE_SEC=1.5

# 单帧图片最大字节数
MAX_IMAGE_BYTES=5242880
